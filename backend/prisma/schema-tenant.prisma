generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

model TenantConfig {
  id               Int      @id @default(autoincrement())
  aiChatbotEnabled Boolean  @default(false)
  useQuickReply    Boolean  @default(true)
  responsePriority String   @default("quickreply")
  customLabels     String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model MasterConfig {
  id            Int                @id @default(autoincrement())
  name          String             @unique
  phoneNumberId String
  wabaId        String?
  appId         String?
  accessToken   String
  verifyToken   String
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  settings      WhatsAppSettings[]
}

model WhatsAppMessage {
  id            Int      @id @default(autoincrement())
  messageId     String   @unique
  to            String
  from          String
  message       String?
  mediaType     String?
  mediaUrl      String?
  direction     String
  status        String
  phoneNumberId String?
  profileName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([phoneNumberId])
  @@index([from, phoneNumberId])
}

model WhatsAppSettings {
  id                     Int                     @id @default(autoincrement())
  name                   String?                 @unique
  templateName           String
  phoneNumberId          String
  accessToken            String
  verifyToken            String?
  apiUrl                 String
  language               String                  @default("en")
  headerImageUrl         String?
  isDefault              Boolean                 @default(false)
  masterConfigId         Int?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  campaigns              Campaign[]
  runDailyAutomation     RunDailyAutomation[]
  runDailyAutomationLogs RunDailyAutomationLog[]
  masterConfig           MasterConfig?           @relation(fields: [masterConfigId], references: [id])
}

model Campaign {
  id            Int               @id @default(autoincrement())
  name          String
  templateName  String
  parameters    Json?
  status        String            @default("draft")
  totalCount    Int               @default(0)
  successCount  Int               @default(0)
  failedCount   Int               @default(0)
  scheduleType  String            @default("one-time")
  scheduledDays String[]          @default([])
  scheduledTime String?
  groupId       Int?
  settingsId    Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  group         Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  settings      WhatsAppSettings  @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  contacts      CampaignContact[]
  messages      CampaignMessage[]
}

model RunDailyAutomation {
  id                     Int                     @id @default(autoincrement())
  whatsAppSettingsId     Int
  contactId              Int
  eventType              AutomationEventType
  dayBefore              Int
  dob                    DateTime?
  anniversary            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  contact                 Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  whatsAppSettings       WhatsAppSettings        @relation(fields: [whatsAppSettingsId], references: [id])
  runDailyAutomationLogs RunDailyAutomationLog[]

  @@unique([contactId, whatsAppSettingsId, eventType, dayBefore])
}

model RunDailyAutomationLog {
  id                   Int                @id @default(autoincrement())
  runDailyAutomationId Int
  contactId            Int
  whatsAppSettingsId   Int
  templateName         String
  status               String
  error                String?
  messageId            String?
  sentAt               DateTime           @default(now())
  sentDate             DateTime
  contact              Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  runDailyAutomation   RunDailyAutomation @relation(fields: [runDailyAutomationId], references: [id], onDelete: Cascade)
  whatsAppSettings     WhatsAppSettings   @relation(fields: [whatsAppSettingsId], references: [id])

  @@unique([runDailyAutomationId, sentDate])
  @@index([sentAt])
  @@index([contactId])
}

model CampaignContact {
  id         Int      @id @default(autoincrement())
  name       String?
  phone      String
  group      String?
  campaignId Int
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignMessage {
  id         Int      @id @default(autoincrement())
  messageId  String?
  phone      String
  name       String?
  status     String
  error      String?
  campaignId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Document {
  id        Int      @id @default(autoincrement())
  filename  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  phone     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id         Int         @id @default(autoincrement())
  message    String
  isFromUser Boolean
  sessionId  Int
  createdAt  DateTime    @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AutoReply {
  id        Int      @id @default(autoincrement())
  triggers  String[]
  response  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickReply {
  id        Int      @id @default(autoincrement())
  title     String
  response  String
  triggers  String[]
  buttons   String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id                     Int                     @id @default(autoincrement())
  name                   String
  email                  String?
  phone                  String
  place                  String?
  lastMessageDate        DateTime?
  dob                    DateTime?
  anniversary            DateTime?
  isActive               Boolean?                @default(true)
  phoneNumberId          String?
  groupId                Int?
  

  variable2              String?
  variable3              String?
  variable4              String?
  variable5              String?
  variable6              String?
  
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  chatNotes              ChatNote[]
  group                  Group?                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  runDailyAutomation     RunDailyAutomation[]
  runDailyAutomationLogs RunDailyAutomationLog[]

  @@unique([phone, phoneNumberId])
  @@index([phoneNumberId])
}

model ChatNote {
  id          Int      @id @default(autoincrement())
  phone       String
  title       String
  description String
  contactId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([contactId])
}

model Group {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaign  Campaign[]
  contact   Contact[]
}

model ChatAssignment {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  subUserId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subUserId])
}

model ChatLabel {
  id             Int      @id @default(autoincrement())
  phone          String   @unique
  labels         String[]
  manuallyEdited Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Test {
  id   Int    @id @default(autoincrement())
  name String
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subCategories SubCategory[]
}

model SubCategory {
  id         Int       @id @default(autoincrement())
  name       String
  categoryId Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId])
}

model Product {
  id            Int              @id @default(autoincrement())
  name          String
  description   String?
  price         Float
  salePrice     Float?
  stock         Int?             @default(0)
  availability  Boolean          @default(true)
  contentId     String?          @unique
  imageUrl      String?
  link          String?
  metaProductId String?
  source        String?          @default("manual")
  subCategoryId Int
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  orderItems    OrderItem[]
  subCategory   SubCategory      @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  variants      ProductVariant[]
}

model ProductVariant {
  id            Int      @id @default(autoincrement())
  productId     Int
  name          String
  description   String?
  price         Float
  salePrice     Float?
  stock         Int?     @default(0)
  imageUrl      String?
  link          String?
  availability  Boolean  @default(true)
  isActive      Boolean  @default(true)
  contentId     String   @unique
  metaProductId String?
  source        String?  @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id              Int         @id @default(autoincrement())
  customerName    String
  customerPhone   String
  customerAddress String?
  customerCity    String?
  customerState   String?
  customerPincode String?
  totalAmount     Float
  shippingAmount  Float?      @default(0)
  status          String      @default("placed")
  paymentMethod   String?
  paymentId       String?
  paymentLink     String?
  paymentStatus   String      @default("pending")
  isAbandoned     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int      @default(1)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model ShoppingSession {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  currentProductId  Int?
  paymentMethod     String?
  step              String   @default("browsing")
  customerName      String?
  customerAddress   String?
  customerCity      String?
  customerPincode   String?
  selectedVariantId Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customerState     String?

  @@index([phone])
  @@index([updatedAt])
}


model ShippingRate {
  id               Int      @id @default(autoincrement())
  state            String   @unique
  flatShippingRate Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
 
model FeatureAssignment {
  id           Int      @id @default(autoincrement())
  whatsappChat String?
  aiChatbot    String?
  quickReply   String?
  ecommerce    String?
  campaigns    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WhatsappFlow {
  id           Int           @id @default(autoincrement())
  name         String
  flowId       String        @unique
  purpose      String
  description  String?
  firstScreen  String        @default("SCREEN")
  triggerWords String[]      @default([])
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     FlowSession[]

  @@index([purpose])
  @@index([flowId])
}

model FlowSession {
  id            Int          @id @default(autoincrement())
  flowToken     String       @unique
  flowId        String
  contactPhone  String
  tenantId      String
  purpose       String
  currentScreen String?
  sessionData   Json         @default("{}")
  status        String       @default("active")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  flow          WhatsappFlow @relation(fields: [flowId], references: [flowId])

  @@index([flowToken])
  @@index([contactPhone])
  @@index([tenantId])
}

model FlowTrigger {
  id          Int              @id @default(autoincrement())
  name        String
  triggerWord String
  flowId      String
  headerText  String?
  bodyText    String?
  footerText  String?
  ctaText     String
  screenName  String           @default("APPOINTMENT")
  screenData  Json             @default("{}")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  logs        FlowTriggerLog[]

  @@index([triggerWord])
}

model FlowTriggerLog {
  id            Int         @id @default(autoincrement())
  flowTriggerId Int
  phoneNumber   String
  triggerWord   String
  status        String
  messageId     String?
  error         String?
  createdAt     DateTime    @default(now())
  flowTrigger   FlowTrigger @relation(fields: [flowTriggerId], references: [id], onDelete: Cascade)

  @@index([flowTriggerId])
  @@index([phoneNumber])
}

model FlowAppointment {
  id          Int      @id @default(autoincrement())
  department  String
  location    String
  date        String
  time        String
  name        String
  email       String
  phone       String
  moreDetails String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phone])
  @@index([date])
}

model FlowDepartment {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlowLocation {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlowTimeSlot {
  id        Int      @id @default(autoincrement())
  time      String
  title     String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id                Int       @id @default(autoincrement())
  templateId        String    @unique
  name              String
  category          String
  language          String
  status            String    @default("PENDING")
  components        String
  sampleValues      String?
  reviewRequested   Boolean   @default(false)
  reviewRequestedAt DateTime?
  reviewReason      String?
  rejectionReason   String?
  previousCategory  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([category])
}

enum AutomationEventType {
  DOB
  ANNIVERSARY
}
