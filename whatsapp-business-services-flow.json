{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SERVICE_SELECTION": [
      "DETAILS"
    ],
    "DETAILS": [
      "SUMMARY"
    ],
    "SUMMARY": [
      "TERMS"
    ],
    "TERMS": []
  },
  "screens": [
    {
      "id": "SERVICE_SELECTION",
      "title": "WhatsApp Business Services",
      "terminal": false,
      "data": {
        "services": {
          "type": "array",
          "__example__": [
            {
              "id": "whatsapp_marketing",
              "title": "WhatsApp Marketing"
            },
            {
              "id": "whatsapp_ecommerce",
              "title": "WhatsApp Ecommerce"
            },
            {
              "id": "ai_chatbot",
              "title": "AI Chat Bot"
            }
          ]
        },
        "date": {
          "type": "array",
          "__example__": [
            {
              "id": "2024-01-15",
              "title": "Mon Jan 15 2024"
            },
            {
              "id": "2024-01-16",
              "title": "Tue Jan 16 2024"
            }
          ]
        },
        "is_date_enabled": {
          "type": "boolean",
          "__example__": true
        },
        "time": {
          "type": "array",
          "__example__": [
            {
              "id": "09:00",
              "title": "09:00 AM"
            },
            {
              "id": "10:00",
              "title": "10:00 AM"
            }
          ]
        },
        "is_time_enabled": {
          "type": "boolean",
          "__example__": true
        },
        "company": {
          "type": "array",
          "__example__": [
            {
              "id": "meta",
              "title": "Meta (WhatsApp Official)"
            },
            {
              "id": "partner",
              "title": "WhatsApp Business Partner"
            }
          ]
        },
        "is_company_enabled": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "service_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Select WhatsApp Business Service"
              },
              {
                "type": "Dropdown",
                "label": "Service Needed",
                "name": "service",
                "data-source": "${data.services}",
                "required": true
              },
              {
                "type": "Dropdown",
                "label": "Preferred Company",
                "name": "company",
                "data-source": "${data.company}",
                "required": "${data.is_company_enabled}",
                "enabled": "${data.is_company_enabled}"
              },
              {
                "type": "Dropdown",
                "label": "Appointment Date",
                "name": "date",
                "data-source": "${data.date}",
                "required": "${data.is_date_enabled}",
                "enabled": "${data.is_date_enabled}"
              },
              {
                "type": "Dropdown",
                "label": "Demo Time",
                "name": "time",
                "data-source": "${data.time}",
                "required": "${data.is_time_enabled}",
                "enabled": "${data.is_time_enabled}"
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "type": "screen",
                    "name": "DETAILS"
                  },
                  "payload": {
                    "service": "${form.service}",
                    "company": "${form.company}",
                    "date": "${form.date}",
                    "time": "${form.time}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "DETAILS",
      "title": "Business Details",
      "terminal": false,
      "data": {
        "service": {
          "type": "string",
          "__example__": "ai_chatbot"
        },
        "company": {
          "type": "string",
          "__example__": "partner"
        },
        "date": {
          "type": "string",
          "__example__": "2024-01-15"
        },
        "time": {
          "type": "string",
          "__example__": "11:00"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "business_details_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Tell us about your business"
              },
              {
                "type": "TextInput",
                "label": "Full Name",
                "name": "name",
                "required": true
              },
              {
                "type": "TextInput",
                "label": "Mobile Number",
                "name": "mobile",
                "input-type": "phone",
                "required": true
              },
              {
                "type": "TextInput",
                "label": "Place / City",
                "name": "place",
                "required": true
              },
              {
                "type": "TextInput",
                "label": "Business Name",
                "name": "business_name",
                "required": true
              },
              {
                "type": "TextInput",
                "label": "Business Type",
                "name": "business_type",
                "required": true
              },
              {
                "type": "Dropdown",
                "label": "Business Size (Employees)",
                "name": "business_size",
                "required": true,
                "data-source": [
                  {
                    "id": "1-5",
                    "title": "1-5 employees"
                  },
                  {
                    "id": "5-10",
                    "title": "5-10 employees"
                  },
                  {
                    "id": "10-20",
                    "title": "10-20 employees"
                  },
                  {
                    "id": "20+",
                    "title": "20+ employees"
                  }
                ]
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "service": "${data.service}",
                    "company": "${data.company}",
                    "date": "${data.date}",
                    "time": "${data.time}",
                    "name": "${form.name}",
                    "mobile": "${form.mobile}",
                    "place": "${form.place}",
                    "business_name": "${form.business_name}",
                    "business_type": "${form.business_type}",
                    "business_size": "${form.business_size}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUMMARY",
      "title": "Review Your Details",
      "terminal": true,
      "data": {
        "service_summary": {
          "type": "string",
          "__example__": "AI Chat Bot consultation with WhatsApp Business Partner on Mon Jan 15 2024 at 11:00 AM"
        },
        "business_summary": {
          "type": "string",
          "__example__": "Name: John Doe\nMobile: +91 98765 43210\nPlace: Mumbai\nBusiness: ABC Enterprises\nType: Retail\nSize: 10-20 employees"
        },
        "service": {
          "type": "string",
          "__example__": "ai_chatbot"
        },
        "company": {
          "type": "string",
          "__example__": "partner"
        },
        "date": {
          "type": "string",
          "__example__": "2024-01-15"
        },
        "time": {
          "type": "string",
          "__example__": "11:00"
        },
        "name": {
          "type": "string",
          "__example__": "John Doe"
        },
        "mobile": {
          "type": "string",
          "__example__": "+91 98765 43210"
        },
        "place": {
          "type": "string",
          "__example__": "Mumbai"
        },
        "business_name": {
          "type": "string",
          "__example__": "ABC Enterprises"
        },
        "business_type": {
          "type": "string",
          "__example__": "Retail"
        },
        "business_size": {
          "type": "string",
          "__example__": "10-20"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "confirmation_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Appointment Summary"
              },
              {
                "type": "TextBody",
                "text": "${data.service_summary}"
              },
              {
                "type": "TextHeading",
                "text": "Business Information"
              },
              {
                "type": "TextBody",
                "text": "${data.business_summary}"
              },
              {
                "type": "OptIn",
                "name": "terms",
                "label": "I agree to the terms and conditions",
                "required": true,
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "type": "screen",
                    "name": "TERMS"
                  },
                  "payload": {}
                }
              },
              {
                "type": "Footer",
                "label": "Confirm & Schedule Demo",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "screen": "CONFIRM_APPOINTMENT",
                    "service": "${data.service}",
                    "company": "${data.company}",
                    "date": "${data.date}",
                    "time": "${data.time}",
                    "name": "${data.name}",
                    "mobile": "${data.mobile}",
                    "place": "${data.place}",
                    "business_name": "${data.business_name}",
                    "business_type": "${data.business_type}",
                    "business_size": "${data.business_size}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "TERMS",
      "title": "Terms and Conditions",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "WhatsApp Business Demo Terms"
          },
          {
            "type": "TextBody",
            "text": "By scheduling a demo, you agree to:\n\n1. We will contact you via WhatsApp or phone at the provided number\n2. Demo sessions last approximately 30-45 minutes\n3. Your business information will be used only for consultation purposes\n4. You can reschedule or cancel up to 2 hours before the appointment\n5. Recording of demos requires prior consent\n\nLorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
          }
        ]
      }
    }
  ]
}
