// Tenant-specific database schema (no userId fields)
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

model TenantConfig {
  id        Int      @id @default(autoincrement())
  aiChatbotEnabled Boolean @default(false)
  useQuickReply Boolean @default(true)
  responsePriority String @default("quickreply")
  customLabels String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterConfig {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  phoneNumberId String
  wabaId        String?
  appId         String?
  accessToken   String
  verifyToken   String
  isActive      Boolean  @default(true)
  settings      WhatsAppSettings[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhatsAppMessage {
  id            Int      @id @default(autoincrement())
  messageId     String   @unique
  to            String
  from          String
  message       String?
  mediaType     String?
  mediaUrl      String?
  direction     String
  status        String
  phoneNumberId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([phoneNumberId])
  @@index([from, phoneNumberId])
}

model WhatsAppSettings {
  id            Int      @id @default(autoincrement())
  name          String?  @unique
  templateName  String
  phoneNumberId String
  accessToken   String
  verifyToken   String?
  apiUrl        String
  language      String   @default("en")
  headerImageUrl String?
  isDefault     Boolean  @default(false)
  masterConfigId Int?
  masterConfig  MasterConfig? @relation(fields: [masterConfigId], references: [id], onDelete: SetNull)
  campaigns     Campaign[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Campaign {
  id           Int      @id @default(autoincrement())
  name         String
  templateName String
  parameters   Json?
  status       String   @default("draft")
  totalCount   Int      @default(0)
  successCount Int      @default(0)
  failedCount  Int      @default(0)
  scheduleType String   @default("one-time")
  scheduledDays String[] @default([])
  scheduledTime String?
  groupId       Int?
  settingsId   Int
  settings     WhatsAppSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  group        Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  contacts     CampaignContact[]
  messages     CampaignMessage[]
}

model CampaignContact {
  id         Int      @id @default(autoincrement())
  name       String?
  phone      String
  group      String?
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model CampaignMessage {
  id         Int      @id @default(autoincrement())
  messageId  String?
  phone      String
  name       String?
  status     String
  error      String?
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Document {
  id        Int      @id @default(autoincrement())
  filename  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        Int      @id @default(autoincrement())
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  messages  ChatMessage[]
}

model ChatMessage {
  id            Int         @id @default(autoincrement())
  message       String
  isFromUser    Boolean
  sessionId     Int
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model AutoReply {
  id        Int      @id @default(autoincrement())
  triggers  String[]
  response  String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickReply {
  id        Int      @id @default(autoincrement())
  triggers  String[]
  buttons   String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id               Int      @id @default(autoincrement())
  name             String
  email            String?
  phone            String
  place            String?
  lastMessageDate  DateTime?
  dob             DateTime?
  anniversary     DateTime?
  isActive         Boolean ? @default(true)
  phoneNumberId    String?
  groupId           Int?
  group             Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([phone, phoneNumberId])
  @@index([phoneNumberId])
}

model Group {
  id                Int  @id @default(autoincrement())
  name              String @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contact         Contact[]
  campaign          Campaign[]
}

model ChatLabel {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  labels    String[]
  manuallyEdited Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Test {
  id       Int     @id @default(autoincrement())
  name     String
}

model Category {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  subCategories SubCategory[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SubCategory {
  id          Int      @id @default(autoincrement())
  name        String
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([name, categoryId])
}

model Product {
  id            Int         @id @default(autoincrement())
  name          String
  description   String?     @db.Text
  price         Float
  salePrice     Float? 
  availability       Boolean     @default(true)
  contentId     String?     @unique  
  imageUrl      String?
  link          String?
  metaProductId String?
  source        String?     @default("manual")
  subCategoryId Int
  isActive      Boolean     @default(true)
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  variants      ProductVariant[] 
}

model ProductVariant {
  id            Int      @id @default(autoincrement())

  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name          String
  description   String?  @db.Text
  price         Float
  salePrice     Float?

  imageUrl      String?
  link          String?

  availability       Boolean  @default(true)
  isActive      Boolean  @default(true)

  contentId     String   @unique      // ✅ REQUIRED/unique for Meta retailer_id per variant
  metaProductId String?               // optional: store Meta returned id
  source        String?  @default("manual")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

model Order {
  id              Int      @id @default(autoincrement())
  customerName    String
  customerPhone   String
  customerAddress String?  @db.Text
  totalAmount     Float
  status          String   @default("placed")
  paymentMethod   String?
  paymentId       String?
  paymentLink     String?
  paymentStatus   String   @default("pending")
  isAbandoned     Boolean  @default(false)
  items           OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int      @default(1)
  price     Float
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([orderId])
  @@index([productId])
}

model ShoppingSession {
  id               Int      @id @default(autoincrement())
  phone            String   @unique
  currentProductId Int?
  paymentMethod    String?
  step             String   @default("browsing")
  customerName     String?
  customerAddress  String?  @db.Text
  customerCity     String?
  customerPincode  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([phone])
  @@index([updatedAt])
}




model FeatureAssignment {
  id           Int      @id @default(autoincrement())
  whatsappChat String?
  aiChatbot    String?
  quickReply   String?
  ecommerce    String?
  campaigns    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FlowTrigger {
  id          Int      @id @default(autoincrement())
  name        String
  triggerWord String
  flowId      String
  headerText  String?
  bodyText    String?
  footerText  String?
  ctaText     String
  screenName  String   @default("APPOINTMENT")
  screenData  Json     @default("{}")
  isActive    Boolean  @default(true)
  logs        FlowTriggerLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([triggerWord])
}

model FlowTriggerLog {
  id             Int      @id @default(autoincrement())
  flowTriggerId  Int
  phoneNumber    String
  triggerWord    String
  status         String
  messageId      String?
  error          String?  @db.Text
  flowTrigger    FlowTrigger @relation(fields: [flowTriggerId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  
  @@index([flowTriggerId])
  @@index([phoneNumber])
}

model FlowAppointment {
  id          Int      @id @default(autoincrement())
  department  String
  location    String
  date        String
  time        String
  name        String
  email       String
  phone       String
  moreDetails String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([phone])
  @@index([date])
}


model FlowDepartment {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlowLocation {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlowTimeSlot {
  id        Int      @id @default(autoincrement())
  time      String
  title     String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id                 Int      @id @default(autoincrement())
  templateId         String   @unique
  name               String
  category           String
  language           String
  status             String   @default("PENDING")
  components         String
  sampleValues       String?  @db.Text
  reviewRequested    Boolean  @default(false)
  reviewRequestedAt  DateTime?
  reviewReason       String?
  rejectionReason    String?
  previousCategory   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@index([status])
  @@index([category])
}
